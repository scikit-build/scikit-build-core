discover:
  how: fmf
  path: .

prepare:
  - how: install
    package:
      - python3-scikit-build-core

adjust+:
  # Cannot use initiator: fedora-ci reliably yet
  when: initiator is not defined or initiator != packit
  discover+:
    dist-git-source: true
    dist-git-extract: scikit_build_core-*/
